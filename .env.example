# =============================================================================
# Core Bank Mandiri - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!
# =============================================================================

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=core_bank
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ------------------------------------------------------------------------------
# Kafka Configuration
# ------------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=notification-service-group

# ------------------------------------------------------------------------------
# SMTP Configuration (Email Notifications)
# ------------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@corebank.co.id

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
SERVER_PORT=8086

# ------------------------------------------------------------------------------
# JWT Configuration (for service-to-service auth)
# ------------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-256-bits-long-for-security

# ------------------------------------------------------------------------------
# SMS Gateway Configuration (Twilio/Vonage)
# ------------------------------------------------------------------------------
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_FROM_NUMBER=+1234567890

# ------------------------------------------------------------------------------
# Push Notification Configuration (FCM)
# ------------------------------------------------------------------------------
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_fcm_project_id

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# ------------------------------------------------------------------------------
# Monitoring Configuration
# ------------------------------------------------------------------------------
PROMETHEUS_PORT=9091
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
