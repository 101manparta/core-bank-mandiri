# =============================================================================
# Core Bank Mandiri - Git Ignore File
# =============================================================================

# ------------------------------------------------------------------------------
# Binaries and Build Output
# ------------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.class
*.jar
*.war
*.ear
bin/
dist/
target/
build/
out/

# Go
*.test
*.out
vendor/

# ------------------------------------------------------------------------------
# Test Files
# ------------------------------------------------------------------------------
*.test
coverage.txt
coverage.out
*.prof
.prof

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# Environment and Secrets (CRITICAL FOR SECURITY)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
*.env
!*.env.example

# Secret keys and credentials
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/
*secret*.yaml
*secret*.json
!*.example.yaml
!*.example.json

# ------------------------------------------------------------------------------
# IDE and Editor
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml
*.docker.local

# ------------------------------------------------------------------------------
# Kubernetes
# ------------------------------------------------------------------------------
# Ignore secret files but keep example templates
*-secrets.yaml
*-secrets.yml
kubeconfig
.kube/

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
data/
*.dump

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------
tmp/
temp/
.cache/
*.tmp
*.bak

# ------------------------------------------------------------------------------
# OS Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# Java/Maven
# ------------------------------------------------------------------------------
.mvn/
mvnw
mvnw.cmd
.m2/

# ------------------------------------------------------------------------------
# Node.js (if used for frontend/tooling)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log

# ------------------------------------------------------------------------------
# Python (if used for scripts/tooling)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
test-results/
test-output/
junit-reports/

# ------------------------------------------------------------------------------
# Documentation Build
# ------------------------------------------------------------------------------
docs/_build/
site/

# ------------------------------------------------------------------------------
# Keep these directories but ignore their contents
# ------------------------------------------------------------------------------
logs/*
!logs/.gitkeep
tmp/*
!tmp/.gitkeep
